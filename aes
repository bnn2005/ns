def simple_cipher(text, key):
    result = ""
    for i in range(len(text)):
        char_code = ord(text[i]) ^ ord(key[i % len(key)])
        result += chr(char_code)
    return result
my_key = "supersecret"
message = "Hello I2IT student!"
encrypted = simple_cipher(message, my_key)
print(f"Encrypted: {repr(encrypted)}")
decrypted = simple_cipher(encrypted, my_key)
print(f"Decrypted: {decrypted}")
