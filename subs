#include <iostream>
using namespace std;
int main() {
    string normal = "ABCDEFGHIJKLMNOPQRSTUVWXYZ";
    string cipher = "QWERTYUIOPASDFGHJKLZXCVBNM";
    string text = "HELLO";
    string encrypted = "";
    string decrypted = "";
    for(int i=0; i<text.length(); i++) {
        char c = text[i];
        for(int j=0; j<26; j++) {
            if(c == normal[j]) {
                encrypted += cipher[j];
                break;
            }
        }
    }
    for(int i=0; i<encrypted.length(); i++) {
        char c = encrypted[i];
        for(int j=0; j<26; j++) {
            if(c == cipher[j]) {
                decrypted += normal[j];
                break;
            }
        }
    }
    cout << "Original  : " << text << endl;
    cout << "Encrypted : " << encrypted << endl;
    cout << "Decrypted : " << decrypted << endl;
    return 0;
}
