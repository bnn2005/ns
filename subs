#include <bits/stdc++.h>
using namespace std;

int main() {
    string ch="abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ";
    map<char,char> e,d;
    int k=4;
    for(int i=0;i<ch.size();i++) {
        e[ch[i]]=ch[(i+k)%ch.size()];
        d[ch[i]]=ch[(i-k+ch.size())%ch.size()];
    }
    string text="Hello World", c="", p="";
    for(char x:text) c += e.count(x)? e[x]:x;
    for(char x:c)    p += d.count(x)? d[x]:x;
    cout<<"Encrypted: "<<c;
    cout<<"\nDecrypted: "<<p;
}
