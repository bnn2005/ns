#include <iostream>
using namespace std;
int main() {
    long long p=7919,q=1009,n=p*q,e=5,d=1596269,M=123,C=1,D=1;
    for(int i=0;i<e;i++) C=(C*M)%n;
    for(int i=0;i<d;i++) D=(D*C)%n;
    cout<<"Original Message: "<<M;
    cout<<"\nEncrypted Message: "<<C;
    cout<<"\nDecrypted Message: "<<D;
}
