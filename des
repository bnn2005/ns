def encrypt(text, key, rounds=4):
    for i in range(rounds):
        temp = ""
        for j in range(len(text)):
            temp += chr((ord(text[j]) + ord(key[j % len(key)])) % 26 + 65)
        text = temp[::-1]   # simple permutation
        print(f"Round {i+1}: {text}")
    return text
text = "HELLOWORLD"
key  = "KEY"
print("Encryption:")
cipher = encrypt(text, key)
print("\nCipher Text:", cipher)
print("\nDecryption:")
plain = encrypt(cipher, key)
print("\nPlain Text:", plain)
